{
    "name": "n8n-nodes-activitysmith",
    "version": "1.0.3",
    "description": "n8n community node for ActivitySmith push notifications and Live Activities",
    "license": "MIT",
    "homepage": "https://activitysmith.com",
    "keywords": [
        "n8n-community-node-package",
        "n8n-nodes-activitysmith",
        "activitysmith",
        "push-notifications",
        "live-activities"
    ],
    "author": {
        "name": "bardonadam",
        "email": "bardon.adam@gmail.com"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ActivitySmithHQ/n8n-nodes-activitysmith.git"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": "n8n-node prerelease"
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": [
            "dist/credentials/ActivitySmithApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/ActivitySmith/ActivitySmith.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "^0.26.0",
        "eslint": "9.32.0",
        "prettier": "3.6.2",
        "release-it": "^19.0.4",
        "typescript": "5.9.2"
    },
    "overrides": {
        "@langchain/classic": "1.0.27",
        "@langchain/community": "1.1.27",
        "@langchain/core": "1.1.39",
        "axios": "1.15.0",
        "brace-expansion": "2.0.3",
        "eslint-plugin-n8n-nodes-base": "1.16.6",
        "form-data": "4.0.5",
        "langsmith": "0.5.18",
        "lodash": "4.18.1",
        "undici": "6.24.1"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    }
}
